    field(DTYP, "stream")
    field(INP,  "@streakcamera.proto devParamGetStr(TD,H Trig. status) $(CPORT)")
    field(ZRST, "Ready")           field(ZRVL, "0")
    field(ONST, "Fired")           field(ONVL, "1")
    field(TWST, "Do Reset")        field(TWVL, "2")
    field(SCAN, "5 second")
