#################################################
####### STREAK CAMERA CONTROL PARAMETERS ########
#################################################
# DEVICE = PVs prefix
# CPORT = RemoteEx commands port (1001)
# DATA_PORT = RemoteEx data port (1002)
#################################################

record(ao, "${DEVICE}GenParams:TimeRange-SP") {
    field(DESC, "Set Time Range from 1-4")
    field(DTYP, "stream")
    field(OUT, "@streakcamera.proto devParamSet(TD,Time Range,%d) $(CPORT)")
}

record(bo, "${DEVICE}GenParams:Mode-Sel") {
    field(DESC, "Set operation mode")
    field(DTYP, "stream")
    field(OUT, "@streakcamera.proto devParamSet(TD,Mode,%s) $(CPORT)")
    field(ZNAM, "Focus")
    field(ONAM, "Operate")
}

record(bo, "${DEVICE}GenParams:GateMode-Sel") {
    field(DESC, "Set gate mode")
    field(DTYP, "stream")
    field(OUT, "@streakcamera.proto devParamSet(TD,Gate Mode,%s) $(CPORT)")
    field(ZNAM, "Normal")
    field(ONAM, "Ext.")
}

record(ao, "${DEVICE}GenParams:MCPGain-SP") {
    field(DESC, "Set MCP gain")
    field(DTYP, "stream")
    field(OUT, "@streakcamera.proto devParamSet(TD,MCP Gain,%d) $(CPORT)")
}

record(bo, "${DEVICE}GenParams:Shutter-Sel") {
    field(DESC, "Set Shutter status")
    field(DTYP, "stream")
    field(OUT, "@streakcamera.proto devParamSet(TD,Shutter,%s) $(CPORT)")
    field(ZRST, "Closed")          field(ZRVL, "0")
    field(ONST, "Open")            field(ONVL, "1")
}

record(mbbo, "${DEVICE}GenParams:BlankingAmp-Sel") {
    field(DESC,  "Set blanking amp time")
    field(DTYP, "stream")
    field(OUT, "@streakcamera.proto devParamSet(TD,Blanking Amp.,%s) $(CPORT)")
    field(ZRST, "off")             field(ZRVL, "0")
    field(ONST, "100 ns")          field(ONVL, "1")
    field(TWST, "200 ns")          field(TWVL, "2")
    field(THST, "500 ns")          field(THVL, "3")
    field(FRST, "1 us")            field(FRVL, "4")
    field(FVST, "2 us")            field(FVVL, "5")
    field(SXST, "5 us")            field(SXVL, "6")
    field(SVST, "10 us")           field(SVVL, "7")
    field(EIST, "20 us")           field(EIVL, "8")
    field(NIST, "50 us")           field(NIVL, "9")
    field(TEST, "100 us")          field(TEVL, "10")
    field(ELST, "200 us")          field(ELVL, "11")
    field(TVST, "500 us")          field(TVVL, "12")
    field(TTST, "1 ms")            field(TTVL, "13")
    field(FTST, "2 ms")            field(FTVL, "14")
    field(FFST, "5 ms")            field(FFVL, "15")
}

record(mbbo, "${DEVICE}GenParams:HTrigStatus-Sel") {
    field(DTYP, "stream")
    field(OUT, "@streakcamera.proto devParamSet(TD,H Trig. status,%s) $(CPORT)")
    field(ZRST, "Ready")           field(ZRVL, "0")
    field(ONST, "Fired")           field(ONVL, "1")
    field(TWST, "Do Reset")        field(TWVL, "2")
}

record(mbbo, "${DEVICE}GenParams:HTrigMode-Sel") {
    field(DTYP, "stream")
    field(OUT, "@streakcamera.proto devParamSet(TD,H Trig. mode,%s) $(CPORT)")
    field(ZRST, "Cont")            field(ZRVL, "0")
    field(ONST, "Single")          field(ONVL, "1")
}

record(ao, "${DEVICE}GenParams:HTrigLevel-SP") {
    field(DTYP, "stream")
    field(OUT, "@streakcamera.proto devParamSet(TD,H Trig. level,%d) $(CPORT)")
}

record(ao, "${DEVICE}GenParams:Delay-SP") {
    field(DTYP, "stream")
    field(OUT, "@streakcamera.proto devParamSet(TD,Delay,%d) $(CPORT)")
}

record(ao, "${DEVICE}GenParams:FocusTimeOver-SP") {
    field(DTYP, "stream")
    field(OUT, "@streakcamera.proto devParamSet(TD,FocusTimeOver,%d) $(CPORT)")
}

## READBACKS

record(ai, "${DEVICE}GenParams:TimeRange-RB") {
    field(DTYP, "stream")
    field(INP,  "@streakcamera.proto devParamGetFloat(TD,Time Range) $(CPORT)")
    field(SCAN, "5 second")
}

record(mbbi, "${DEVICE}GenParams:Mode-RB") {
    field(DTYP, "stream")
    field(INP,  "@streakcamera.proto devParamGetStr(TD,Mode) $(CPORT)")
    field(ZRST, "Focus")           field(ZRVL, "0")
    field(ONST, "Operate")         field(ONVL, "1")
    field(SCAN, "5 second")
}

record(mbbi, "${DEVICE}GenParams:GateMode-RB") {
    field(DTYP, "stream")
    field(INP,  "@streakcamera.proto devParamGetStr(TD,Gate Mode) $(CPORT)")
    field(ZRST, "Normal")          field(ZRVL, "0")
    field(ONST, "Ext.")            field(ONVL, "1")
