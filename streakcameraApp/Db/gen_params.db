record(ai, "${DEVICE}GenParams:HTrigLevel-RB") {
    field(DTYP, "stream")
    field(INP,  "@streakcamera.proto devParamGetFloat(TD,H Trig. level) $(CPORT)")
    field(SCAN, "5 second")
