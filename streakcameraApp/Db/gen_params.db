    field(DTYP, "stream")
    field(INP,  "@streakcamera.proto devParamGetStr(TD,H Trig. mode) $(CPORT)")
    field(ZRST, "Cont")            field(ZRVL, "0")
    field(ONST, "Single")          field(ONVL, "1")
    field(SCAN, "5 second")
